# Parclose configuration — copy to `.env` and fill in your own values.
# `.env` and other real env files are gitignored; only this example is committed.
# Nothing here is a secret: every value is a placeholder.

# ──────────────────────────────────────────────────────────────────────────
# Reasoning model — consumed today by the agents' live path
# (`cd agents && cargo run --example live_compete`).
# Without ANTHROPIC_API_KEY the agents fall back to the offline reasoning
# stand-in used by the tests and `cargo run --example compete`.
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional overrides (sensible defaults are built in):
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# ──────────────────────────────────────────────────────────────────────────
# Casper Testnet — added as the deploy / on-chain paths land.
# Listed up front so the deployment surface is documented; not yet read by the
# code. All endpoints, keys, and addresses are env-driven (never hard-coded).
# ──────────────────────────────────────────────────────────────────────────
CASPER_NODE_RPC_URL=
CASPER_NETWORK_NAME=casper-test
# Deployer / demo account secret-key file (PEM). Never commit a real key.
CASPER_SECRET_KEY_PATH=

# Deployed contract addresses (filled in after deployment):
SEALED_ORDER_BOOK_ADDRESS=
CROSSING_ENGINE_ADDRESS=
FUND_TOKEN_ADDRESS=
CASH_TOKEN_ADDRESS=
WINDOW_REGISTRY_ADDRESS=

# Enclave trust root configured on CrossingEngine:
ENCLAVE_PUBKEY=
ENCLAVE_MEASUREMENT=

# Attested NAV / market-data source the agents perceive (a clearly-labeled
# stand-in feed is acceptable for the demo):
NAV_SOURCE_URL=
